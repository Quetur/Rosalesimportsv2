<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>RosalesImports</title>
    <link rel="icon" href="/img/logo.png" type="image/png">
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>
    <header class="top-navbar">
        <div class="nav-left">
            <a href="/" style="display: flex; align-items: center; text-decoration: none; color: inherit;">
                <img src="/img/logo.jpg" alt="Logo" class="nav-logo">
                <span class="brand-name">RosalesImports</span>
            </a>
        </div>

        <div class="nav-right">
            <!-- Icono de Carrito Restaurado -->
            <!-- Icono de Carrito en formato SVG (Inmune a errores de fuentes) -->
            <a href="/carritobarra" class="cart-link">
                <svg class="cart-icon-svg" xmlns="http://www.w3.org" viewBox="0 0 576 512">
                    <path
                        d="M0 24C0 10.7 10.7 0 24 0L69.5 0c22 0 41.5 12.8 50.6 32L109 32l325.4 0c21.4 0 39.6 15 44 35.9L533.1 230.6c3 14.2-2 28.6-13 38.2S493.5 281.6 479 281.6L169.6 281.6L143.7 346.4l304.3 0c13.3 0 24 10.7 24 24s-10.7 24-24 24L114.3 394.8c-11.4 0-21.7-6.4-26.7-16.5l-104-260C38.9 107.4 24 90.1 24 70.5L24 48 24 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm336-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z" />
                </svg>
                <span id="items" class="cart-count">0</span>
            </a>


            <!-- Menú Hamburguesa Usuario (Estilo Profesional) -->
            <div id="adminContainer" class="admin-menu-container" style="display: none;">
                <input type="checkbox" id="menu-toggle">

                <label for="menu-toggle" class="nav-btn-professional">
                    <i class="fas fa-user-circle"></i> <!-- Cambié bars por user-circle para más profesionalismo -->
                    <span id="nombreUsuarioMenu" class="user-name-text">ADMIN</span>
                </label>


                <ul class="admin-dropdown">
                    <li><a href="/productocambia">Productos</a></li>
                    <li><a href="/categorialista">Categorias</a></li>
                    <li class="menu-divider"></li>
                    <li><a href="#" id="btnSalirMenu">Salir</a></li>
                </ul>
            </div>

            <!-- Botón Acceso (Mismo Estilo Profesional) -->
            <a href="/signin" id="btnAcceso" class="nav-btn-professional">Administracion</a>
        </div>
    </header>

    <div class="layout-container">
        {{#unless hideSidebar}}
        {{> sidebar }}
        {{/unless}}

        <main id="main-content" class="content {{#if hideSidebar}}full-width{{else}}full-width expanded{{/if}}">
            {{{body}}}
        </main>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const token = sessionStorage.getItem('token_acceso');
            const nombre = sessionStorage.getItem('nombre');

            const ui = {
                adminContainer: document.getElementById('adminContainer'),
                nombreLabel: document.getElementById('nombreUsuarioMenu'),
                acceso: document.getElementById('btnAcceso'),
                itemsCount: document.getElementById('items'),
                sidebar: document.getElementById('sidebar'),
                toggleBtn: document.getElementById('toggle-btn'),
                content: document.getElementById('main-content'),
                btnSalirMenu: document.getElementById('btnSalirMenu')
            };

            const cerrarSesion = (e) => {
                if (e) e.preventDefault();
                sessionStorage.clear();
                localStorage.removeItem('token_acceso');
                localStorage.removeItem('nombre');
                window.location.href = '/signin';
            };

            if (token) {
                if (ui.adminContainer) ui.adminContainer.style.display = 'flex';
                if (ui.nombreLabel) ui.nombreLabel.textContent = nombre || "Usuario";
                if (ui.acceso) ui.acceso.style.display = 'none';
            } else {
                if (ui.adminContainer) ui.adminContainer.style.display = 'none';
                if (ui.acceso) ui.acceso.style.display = 'inline-flex';
            }

            if (ui.btnSalirMenu) ui.btnSalirMenu.addEventListener('click', cerrarSesion);

            if (ui.toggleBtn && ui.sidebar) {
                ui.sidebar.classList.add('collapsed');
                if (ui.content) ui.content.classList.add('expanded');
                const icono = ui.toggleBtn.querySelector('.icon-arrow') || ui.toggleBtn;

                ui.toggleBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    ui.sidebar.classList.toggle('collapsed');
                    if (ui.content) ui.content.classList.toggle('expanded');
                    icono.innerText = ui.sidebar.classList.contains('collapsed') ? '➔' : '⬅';
                });
            }

            actualizarContadorCarrito();
        });

        function actualizarContadorCarrito() {
            const carrito = JSON.parse(localStorage.getItem('productos')) || [];
            const totalItems = carrito.reduce((acc, p) => acc + parseInt(p.cant || 0), 0);
            const contador = document.getElementById('items');
            if (contador) contador.textContent = totalItems;
        }
    </script>
</body>

</html>